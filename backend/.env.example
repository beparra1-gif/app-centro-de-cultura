# DATABASE
DATABASE_URL=postgresql://user:password@localhost:5432/ccf_db

# SERVER
PORT=3000
NODE_ENV=development

# JWT (para autenticación futura)
JWT_SECRET=tu-secreto-super-seguro-cambiar-en-prod

# WHATSAPP API (Twilio)
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# GOOGLE SHEETS (para sincronización)
GOOGLE_SHEET_ID=tu-sheet-id
GOOGLE_API_KEY=tu-api-key
SHEETS_TAB_JUGADORES=Jugadores
SHEETS_TAB_SOCIOS=Socios
ADMIN_SYNC_TOKEN=token-seguro-para-sync

# FRONTEND URL (para CORS)
FRONTEND_URL=http://localhost:5173

# SUPER ADMIN (bootstrap opcional en arranque)
AUTO_BOOTSTRAP_SUPER_ADMIN=false
SUPER_ADMIN_EMAIL=superadmin@ccf.local
SUPER_ADMIN_RUT=11111111-1
SUPER_ADMIN_PASSWORD=AdminCCF2026!
SUPER_ADMIN_NOMBRES=Super
SUPER_ADMIN_APELLIDO=Admin
