# DATABASE
DATABASE_URL=postgresql://user:password@localhost:5432/ccf_db

# SERVER
PORT=3000
NODE_ENV=development

# JWT (para autenticación futura)
JWT_SECRET=tu-secreto-super-seguro-cambiar-en-prod

# WHATSAPP API (Twilio)
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# GOOGLE SHEETS (para sincronización)
GOOGLE_SHEET_ID=tu-sheet-id
GOOGLE_API_KEY=tu-api-key
SHEETS_TAB_JUGADORES=Jugadores
SHEETS_TAB_SOCIOS=Socios
ADMIN_SYNC_TOKEN=token-seguro-para-sync

# GOOGLE SHEETS - ESPEJO AUTOMATICO (App -> Sheet, escritura real vía Sheets API)
# Requiere una cuenta de servicio de Google Cloud con la Sheets API habilitada,
# compartida como Editor en el Google Sheet (GOOGLE_SHEET_ID de arriba).
# Sin esto, GOOGLE_SHEET_BIDIRECTIONAL_SYNC queda inactivo aunque esté en true.
GOOGLE_SHEET_BIDIRECTIONAL_SYNC=false
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
GOOGLE_SHEET_SYNC_DEBOUNCE_MS=4000

# GOOGLE SHEETS WEBHOOK (ruta sin costo con Apps Script)
GOOGLE_SHEETS_WEBHOOK_ENABLED=true
# Ejemplo: https://script.google.com/macros/s/<DEPLOYMENT_ID>/exec?token=<TOKEN>
GOOGLE_SHEETS_WEBHOOK_URL=
GOOGLE_SHEETS_WEBHOOK_TOKEN=
GOOGLE_SHEETS_WEBHOOK_DEBOUNCE_MS=2500

# BACKUPS (estado operativo)
# Opción A: ruta a carpeta de backups (archivos .sql/.dump/.backup/.bak/.gz)
BACKUP_DIR=./backups
# Opción B: ruta a manifest JSON generado por tu job de backup
# Ejemplo: {"lastSuccessAt":"2026-07-10T03:15:00.000Z","filePath":"/var/backups/ccf_20260710.dump"}
BACKUP_MANIFEST_PATH=
# Ventana máxima para considerar backup saludable
BACKUP_MAX_AGE_HOURS=36
BACKUP_ENABLED=true
BACKUP_CRON=0 */6 * * *
BACKUP_KEEP_DAYS=7
BACKUP_KEEP_MAX_FILES=48
# En false para desarrollo local: con nodemon (npm run dev), un backup en
# cada arranque escribe un archivo dentro de BACKUP_DIR (backups/), que al
# estar dentro de backend/ dispara otro reinicio de nodemon, que dispara
# otro backup — un loop de reinicios infinito. En producción (npm start,
# sin nodemon) sí conviene en true; ver backend/app.yaml.
BACKUP_RUN_ON_START=false
BACKUP_ALLOW_JSON_FALLBACK=true

# Subida de respaldo a storage externo (S3 / DigitalOcean Spaces)
BACKUP_UPLOAD_ENABLED=false
BACKUP_UPLOAD_REQUIRED=false
BACKUP_S3_ENDPOINT=https://nyc3.digitaloceanspaces.com
BACKUP_S3_REGION=us-east-1
BACKUP_S3_BUCKET=ccf-backups
BACKUP_S3_PREFIX=ccf-db-backups
BACKUP_S3_ACCESS_KEY_ID=
BACKUP_S3_SECRET_ACCESS_KEY=

# FRONTEND URL (para CORS)
FRONTEND_URL=http://localhost:5173

# SUPER ADMIN (bootstrap opcional en arranque)
AUTO_BOOTSTRAP_SUPER_ADMIN=false
SUPER_ADMIN_EMAIL=superadmin@ccf.local
SUPER_ADMIN_RUT=11111111-1
SUPER_ADMIN_PASSWORD=AdminCCF2026!
SUPER_ADMIN_NOMBRES=Super
SUPER_ADMIN_APELLIDO=Admin
